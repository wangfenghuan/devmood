{
  "name": "devmood",
  "version": "1.0.0",
  "description": "DevMood 开发者状态助手 - 根据键盘鼠标行为自动识别专注/疲劳/卡住/烦躁状态",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.electron.json && electron .\"",
    "electron:build": "npm run build && tsc -p tsconfig.electron.json && electron-builder",
    "electron:start": "electron ."
  },
  "keywords": [
    "developer",
    "mood",
    "productivity",
    "focus",
    "fatigue"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "active-win": "^8.2.1",
    "antd": "^6.1.3",
    "better-sqlite3": "^11.7.0",
    "brain.js": "^2.0.0-beta.24",
    "date-fns": "^4.1.0",
    "gpu.js": "npm:gpu-mock.js@^1.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.1",
    "sql.js": "^1.14.1",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "electron": "^35.0.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.devmood.app",
    "productName": "DevMood",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    }
  }
}
